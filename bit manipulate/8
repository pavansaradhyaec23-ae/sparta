count number of set bits




#include <stdio.h>

int main() {
    int n;
    printf("the num: ");
    scanf("%d",&n);
    int sum=0;
    for(int i=0; i<4 ;i++){
        sum=sum+((n>>i)&1);
    }
    printf("the number of set bits = %d ",sum);
    return 0;
}


better method: Brian Kernighan Algorithm



#include <stdio.h>

int main()
{
    int n;
    int count = 0;

    printf("Enter a number: ");
    scanf("%d", &n);

    while (n )
    {
        n = n & (n - 1);   // Clears the rightmost set bit
        count++;
    }

    printf("Number of set bits = %d\n", count);

    return 0;
}
