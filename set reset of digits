uint32_t bits(uint32_t word,uint8_t bitno){
 word |= 1<<bitno;
 return word;
 }
 
 
 uint32_t bitr(uint32_t dat,uint8_t bitn){
     dat &= ~(1<<bitn);
     
     
     return dat;
 }
